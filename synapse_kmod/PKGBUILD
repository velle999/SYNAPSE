pkgname=synapse_kmod
pkgver=0.1.0
pkgrel=1
pkgdesc="SynapseOS kernel module — AI_CTX syscalls, kprobes, AI scheduler bridge"
arch=('x86_64')
license=('GPL2')
depends=('linux')
options=('!strip')
source=("$pkgname-$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "$srcdir/$pkgname-$pkgver"

    install -Dm644 synapse_kmod.ko \
        "$pkgdir/usr/lib/modules/6.19.6-arch1-1/extra/synapse_kmod.ko"

    install -Dm755 tools/syn-kmod-status \
        "$pkgdir/usr/bin/syn-kmod-status" 2>/dev/null || true

    install -Dm644 /dev/null \
        "$pkgdir/usr/lib/modules-load.d/synapse.conf"
    echo "synapse_kmod" > "$pkgdir/usr/lib/modules-load.d/synapse.conf"

    install -Dm644 /dev/null \
        "$pkgdir/usr/lib/modprobe.d/synapse.conf"
    echo "options synapse_kmod synapse_events=1 synapse_sched=1 synapse_daemon_timeout=30 synapse_ring_size=4096" \
        > "$pkgdir/usr/lib/modprobe.d/synapse.conf"
}
