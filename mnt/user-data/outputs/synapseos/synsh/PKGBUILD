# Maintainer: SynapseOS Project <dev@synapseos.dev>
# PKGBUILD — synsh (SynapseOS Natural Language Shell)

pkgname=synsh
pkgver=0.1.0
pkgrel=1
pkgdesc="SynapseOS natural language shell — AI-native command interface"
arch=('x86_64' 'aarch64' 'riscv64')
url="https://github.com/synapseos/synapseos"
license=('GPL2')
depends=(
    'glibc'
    'readline'
)
makedepends=(
    'meson'
    'ninja'
    'gcc'
)
optdepends=(
    'synapd: AI translation backend (required for AI features)'
)
backup=('etc/synsh/synshrc')
install=synsh.install

source=("$pkgname-$pkgver.tar.gz::https://github.com/synapseos/synapseos/archive/refs/tags/synsh-$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/synapseos-synsh-$pkgver"
    meson setup build \
        --prefix=/usr \
        --buildtype=release \
        -Dreadline=enabled \
        -Db_lto=true \
        -Db_pie=true
    meson compile -C build
}

package() {
    cd "$srcdir/synapseos-synsh-$pkgver"
    meson install -C build --destdir="$pkgdir"

    install -dm755 "$pkgdir/etc/synsh"
    install -Dm644 config/synshrc "$pkgdir/etc/synsh/synshrc"

    # Add synsh to /etc/shells
    echo '/usr/bin/synsh' >> "$pkgdir/etc/shells" 2>/dev/null || true
}
