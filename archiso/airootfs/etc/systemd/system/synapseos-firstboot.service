[Unit]
Description=SynapseOS First Boot Setup Wizard
ConditionPathExists=!/var/lib/synapseos/firstboot.done
After=network-online.target synapd.service seatd.service
Wants=network-online.target
Before=synui.service

[Service]
Type=oneshot
ExecStart=/usr/bin/syn-firstboot
RemainAfterExit=yes
StandardInput=tty
StandardOutput=tty
StandardError=journal
TTYPath=/dev/tty1
TTYVHangup=yes

[Install]
WantedBy=multi-user.target
