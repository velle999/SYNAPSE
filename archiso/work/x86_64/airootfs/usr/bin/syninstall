#!/usr/bin/env bash
# syninstall — SynapseOS Guided Installer
#
# A minimal, readable bash TUI installer.
# No Python, no Qt, no Calamares — just bash + dialog.
#
# Installs SynapseOS to a target disk using pacstrap.
#
# Usage:
#   syninstall            — guided mode (recommended)
#   syninstall --auto     — non-interactive with defaults (dangerous!)
#   syninstall --help
#
# SynapseOS Project — GPLv2

set -euo pipefail

SYNAPSEOS_VERSION="0.1.0"
LOG="/tmp/syninstall.log"
MOUNT_POINT="/mnt"

# ── Colors (no dialog for these) ──────────────────────────────
C_BRAND='\033[38;5;51m'
C_OK='\033[38;5;82m'
C_ERR='\033[38;5;196m'
C_RESET='\033[0m'

log()  { echo "[$(date +%H:%M:%S)] $*" >> "$LOG"; echo -e "${C_BRAND}▶${C_RESET} $*"; }
ok()   { echo "[$(date +%H:%M:%S)] OK: $*" >> "$LOG"; echo -e "${C_OK}✓${C_RESET} $*"; }
err()  { echo "[$(date +%H:%M:%S)] ERR: $*" >> "$LOG"; echo -e "${C_ERR}✗${C_RESET} $*" >&2; exit 1; }

# ── Preflight ─────────────────────────────────────────────────
[[ "$(id -u)" -eq 0 ]] || err "Run as root: sudo syninstall"
command -v dialog &>/dev/null || pacman -Sy --noconfirm dialog

# ── dialog helpers ────────────────────────────────────────────
d_msg() {
    dialog --backtitle "SynapseOS Installer" \
           --title "$1" --msgbox "$2" 12 60
}
d_yesno() {
    dialog --backtitle "SynapseOS Installer" \
           --title "$1" --yesno "$2" 10 60
}
d_input() {
    dialog --backtitle "SynapseOS Installer" \
           --title "$1" --inputbox "$2" 10 60 "$3" \
           3>&1 1>&2 2>&3
}
d_menu() {
    dialog --backtitle "SynapseOS Installer" \
           --title "$1" --menu "$2" 20 60 12 "${@:3}" \
           3>&1 1>&2 2>&3
}
d_checklist() {
    dialog --backtitle "SynapseOS Installer" \
           --title "$1" --checklist "$2" 20 70 12 "${@:3}" \
           3>&1 1>&2 2>&3
}
d_progress() {
    dialog --backtitle "SynapseOS Installer" \
           --title "$1" --gauge "$2" 8 60 "$3"
}

# ── Welcome ───────────────────────────────────────────────────
clear
dialog --backtitle "SynapseOS Installer" \
       --title "⚡ Welcome to SynapseOS ${SYNAPSEOS_VERSION}" \
       --msgbox "\n\
SynapseOS — Where the kernel thinks.\n\
\n\
This installer will guide you through installing SynapseOS\n\
to your hard drive.\n\
\n\
What will be installed:\n\
  • Linux kernel with AI_CTX extensions\n\
  • synapd  — AI inference daemon\n\
  • synguard — AI security monitor\n\
  • synui    — AI-native Wayland compositor\n\
  • synsh    — Natural language shell\n\
  • synapse-7b model (~4GB)\n\
\n\
The installer will partition your disk. Make sure you have\n\
backed up any important data.\n\
" 20 65

# ── Locale ────────────────────────────────────────────────────
LOCALE=$(d_menu "Locale" "Select your locale:" \
    "en_US.UTF-8" "English (US)" \
    "en_GB.UTF-8" "English (UK)" \
    "de_DE.UTF-8" "Deutsch" \
    "fr_FR.UTF-8" "Français" \
    "ja_JP.UTF-8" "日本語" \
    "zh_CN.UTF-8" "中文 (简体)" \
    "es_ES.UTF-8" "Español" \
    "other"       "Enter manually..."
)
[[ "$LOCALE" == "other" ]] && LOCALE=$(d_input "Locale" "Enter locale (e.g. pt_BR.UTF-8):" "")

TIMEZONE=$(d_input "Timezone" \
    "Enter timezone (e.g. America/New_York, Europe/London):" \
    "UTC")

KEYMAP=$(d_menu "Keyboard" "Select keymap:" \
    "us"     "US" \
    "uk"     "UK" \
    "de"     "German" \
    "fr"     "French" \
    "es"     "Spanish" \
    "dvorak" "Dvorak" \
    "other"  "Enter manually..."
)
[[ "$KEYMAP" == "other" ]] && KEYMAP=$(d_input "Keymap" "Enter keymap:" "us")

# ── Hostname ──────────────────────────────────────────────────
HOSTNAME=$(d_input "Hostname" "Enter hostname for this machine:" "synapse")

# ── User account ──────────────────────────────────────────────
USERNAME=$(d_input "User" "Enter your username:" "syn")
USER_FULL=$(d_input "Full Name" "Enter your full name (optional):" "")

# Password (dialog --passwordbox)
USER_PASS=$(dialog --backtitle "SynapseOS Installer" \
    --title "Password" --passwordbox \
    "Enter password for ${USERNAME}:" 10 50 \
    3>&1 1>&2 2>&3)

USER_PASS2=$(dialog --backtitle "SynapseOS Installer" \
    --title "Password" --passwordbox \
    "Confirm password:" 10 50 \
    3>&1 1>&2 2>&3)

[[ "$USER_PASS" == "$USER_PASS2" ]] || { d_msg "Error" "Passwords do not match!"; exec "$0"; }

# ── Disk selection ────────────────────────────────────────────
# Build disk list from lsblk
DISK_ARGS=()
while IFS= read -r line; do
    DEV=$(echo "$line" | awk '{print $1}')
    SIZE=$(echo "$line" | awk '{print $2}')
    MODEL=$(echo "$line" | awk '{$1=$2=""; print $0}' | xargs)
    DISK_ARGS+=("/dev/${DEV}" "${SIZE} — ${MODEL}")
done < <(lsblk -d -n -o NAME,SIZE,MODEL | grep -v "loop\|sr")

TARGET_DISK=$(d_menu "Target Disk" \
    "⚠ WARNING: All data on the selected disk will be ERASED.\n\nSelect installation target:" \
    "${DISK_ARGS[@]}")

d_yesno "Confirm" \
    "Are you SURE you want to erase ${TARGET_DISK} and install SynapseOS?\n\nThis CANNOT be undone." \
    || exec "$0"

# ── Partition scheme ──────────────────────────────────────────
SCHEME=$(d_menu "Partition Scheme" "Select partition layout:" \
    "auto_btrfs"  "Auto — Btrfs with subvolumes (recommended)" \
    "auto_ext4"   "Auto — ext4" \
    "manual"      "Manual — open fdisk/cfdisk"
)

# ── AI features ───────────────────────────────────────────────
AI_FEATURES=$(d_checklist "AI Features" \
    "Select which AI features to enable:" \
    "synapd"    "synapd — AI inference daemon"  "on" \
    "synguard"  "synguard — AI security monitor" "on" \
    "synui"     "synui — AI compositor"         "on" \
    "model"     "Embed synapse-7b model (~4GB)" "on"
) || AI_FEATURES="synapd synguard synui model"

# ── Desktop environment ──────────────────────────────────────
DESKTOP=$(d_menu "Desktop Environment" \
    "Select your desktop environment:" \
    "synui"   "SynapseUI — AI-native Wayland compositor (default)" \
    "kde"     "KDE Plasma — Full-featured Wayland desktop" \
    "gnome"   "GNOME — Clean, modern Wayland desktop" \
    "tty"     "TTY only — No GUI (headless/server)"
)

# ── Summary ───────────────────────────────────────────────────
d_yesno "Summary — Review before installing" \
"The following will be configured:\n\
\n\
  Locale:    ${LOCALE}\n\
  Timezone:  ${TIMEZONE}\n\
  Keymap:    ${KEYMAP}\n\
  Hostname:  ${HOSTNAME}\n\
  User:      ${USERNAME}\n\
  Disk:      ${TARGET_DISK} (WILL BE ERASED)\n\
  Scheme:    ${SCHEME}\n\
  Desktop:   ${DESKTOP}\n\
  AI:        ${AI_FEATURES}\n\
\n\
Proceed with installation?" || exec "$0"

# ── Installation ──────────────────────────────────────────────
clear
echo -e "${C_BRAND}⚡ Installing SynapseOS...${C_RESET}"
echo   "   Log: $LOG"
echo

do_install() {

# ── Partition ──────────────────────────────────────────────
log "Partitioning ${TARGET_DISK}..."
if [[ "$SCHEME" == "manual" ]]; then
    cfdisk "${TARGET_DISK}"
    # User partitions manually
    BOOT_PART=$(lsblk -n -o NAME "${TARGET_DISK}" | grep -v "$(basename "${TARGET_DISK}")" | head -1)
    ROOT_PART=$(lsblk -n -o NAME "${TARGET_DISK}" | grep -v "$(basename "${TARGET_DISK}")" | sed -n '2p')
    BOOT_PART="/dev/${BOOT_PART}"
    ROOT_PART="/dev/${ROOT_PART}"
else
    # Auto partitioning: 1GB EFI + rest for root
    parted -s "${TARGET_DISK}" \
        mklabel gpt \
        mkpart ESP fat32 1MiB 1025MiB \
        set 1 esp on \
        mkpart root 1025MiB 100%

    # Kernel needs to re-read partition table
    partprobe "${TARGET_DISK}" 2>/dev/null || true
    sleep 1

    # Determine partition names (nvme uses p1/p2, sda uses 1/2)
    if [[ "${TARGET_DISK}" == *"nvme"* ]]; then
        BOOT_PART="${TARGET_DISK}p1"
        ROOT_PART="${TARGET_DISK}p2"
    else
        BOOT_PART="${TARGET_DISK}1"
        ROOT_PART="${TARGET_DISK}2"
    fi
fi

# ── Format ────────────────────────────────────────────────
log "Formatting partitions..."
mkfs.fat -F32 -n "SYNBOOT" "${BOOT_PART}"

case "$SCHEME" in
    auto_btrfs)
        mkfs.btrfs -f -L "SynapseOS" "${ROOT_PART}"
        mount "${ROOT_PART}" "${MOUNT_POINT}"
        btrfs subvolume create "${MOUNT_POINT}/@"
        btrfs subvolume create "${MOUNT_POINT}/@home"
        btrfs subvolume create "${MOUNT_POINT}/@var"
        btrfs subvolume create "${MOUNT_POINT}/@snapshots"
        umount "${MOUNT_POINT}"
        MOUNT_OPTS="compress=zstd:3,noatime,ssd,space_cache=v2"
        mount -o "${MOUNT_OPTS},subvol=@"          "${ROOT_PART}" "${MOUNT_POINT}"
        mkdir -p "${MOUNT_POINT}"/{home,var,.snapshots,boot}
        mount -o "${MOUNT_OPTS},subvol=@home"      "${ROOT_PART}" "${MOUNT_POINT}/home"
        mount -o "${MOUNT_OPTS},subvol=@var"       "${ROOT_PART}" "${MOUNT_POINT}/var"
        mount -o "${MOUNT_OPTS},subvol=@snapshots" "${ROOT_PART}" "${MOUNT_POINT}/.snapshots"
        ;;
    auto_ext4)
        mkfs.ext4 -L "SynapseOS" "${ROOT_PART}"
        mount "${ROOT_PART}" "${MOUNT_POINT}"
        mkdir -p "${MOUNT_POINT}/boot"
        ;;
esac

mkdir -p "${MOUNT_POINT}/boot/efi"
mount "${BOOT_PART}" "${MOUNT_POINT}/boot/efi"

ok "Partitions mounted"

# ── pacstrap ──────────────────────────────────────────────
log "Installing base system (this takes a while)..."

# Build DE-specific package list
DE_PKGS=""
case "${DESKTOP}" in
    synui)
        DE_PKGS="foot xdg-desktop-portal"
        ;;
    kde)
        DE_PKGS="plasma-desktop sddm konsole kscreen plasma-nm plasma-pa xdg-desktop-portal-kde"
        ;;
    gnome)
        DE_PKGS="gnome-shell gnome-control-center gdm gnome-terminal xdg-desktop-portal-gnome"
        ;;
    tty)
        DE_PKGS=""
        ;;
esac

pacstrap -K "${MOUNT_POINT}" \
    base base-devel linux linux-firmware \
    linux-headers dkms \
    networkmanager grub efibootmgr \
    seatd \
    sudo nano vim \
    ${DE_PKGS} \
    2>&1 | tee -a "$LOG"

# ── SynapseOS packages ────────────────────────────────────
log "Installing SynapseOS packages..."
# Copy local repo (packages + database) into the new system
LIVE_REPO="/run/archiso/airootfs/local-repo"
# Fallback: on some archiso layouts the repo is at /local-repo
[[ -d "$LIVE_REPO" ]] || LIVE_REPO="/local-repo"

if [[ -d "$LIVE_REPO" ]]; then
    mkdir -p "${MOUNT_POINT}/var/cache/synapseos-repo"
    cp "$LIVE_REPO"/*.pkg.tar.zst "${MOUNT_POINT}/var/cache/synapseos-repo/" 2>/dev/null || true
    cp "$LIVE_REPO"/synapseos.db* "${MOUNT_POINT}/var/cache/synapseos-repo/" 2>/dev/null || true
    cp "$LIVE_REPO"/synapseos.files* "${MOUNT_POINT}/var/cache/synapseos-repo/" 2>/dev/null || true
    ok "Local repo copied to installed system"
else
    log "Warning: local repo not found — SynapseOS packages may be missing"
fi

arch-chroot "${MOUNT_POINT}" /bin/bash -s << CHROOT
set -e

# Add local repo
cat >> /etc/pacman.conf << 'REPO'

[synapseos]
SigLevel = Optional TrustAll
Server = file:///var/cache/synapseos-repo
REPO

pacman -Sy 2>/dev/null || true

# Install SynapseOS components
for pkg in synapd synsh synguard synui synapse_kmod syn-firstboot syn-install; do
    pacman -S --noconfirm "\$pkg" 2>/dev/null || echo "Note: \$pkg not in local repo"
done

# Regenerate repo database if it wasn't copied
if [[ ! -f /var/cache/synapseos-repo/synapseos.db.tar.gz ]] && \
   ls /var/cache/synapseos-repo/*.pkg.tar.zst &>/dev/null; then
    repo-add /var/cache/synapseos-repo/synapseos.db.tar.gz \
        /var/cache/synapseos-repo/*.pkg.tar.zst 2>/dev/null || true
    pacman -Sy 2>/dev/null || true
    for pkg in synapd synsh synguard synui synapse_kmod syn-firstboot syn-install; do
        pacman -S --noconfirm "\$pkg" 2>/dev/null || true
    done
fi

CHROOT

# ── Fallback: copy DKMS source and kmod-build if pkg missed them ──
if [[ ! -d "${MOUNT_POINT}/usr/src/synapse_kmod-0.1.0" ]]; then
    KMOD_SRC="/usr/src/synapse_kmod-0.1.0"
    [[ -d "$KMOD_SRC" ]] || KMOD_SRC=$(ls -d /usr/src/synapse_kmod* 2>/dev/null | head -1) || true
    if [[ -n "$KMOD_SRC" && -d "$KMOD_SRC" ]]; then
        log "Copying DKMS source tree as fallback..."
        mkdir -p "${MOUNT_POINT}/usr/src/synapse_kmod-0.1.0"
        cp -a "$KMOD_SRC"/. "${MOUNT_POINT}/usr/src/synapse_kmod-0.1.0/"
        ok "DKMS source installed"
    fi
fi
# Copy kmod-build script as fallback
if [[ ! -f "${MOUNT_POINT}/usr/bin/synapse-kmod-build" ]] && \
   [[ -f /usr/bin/synapse-kmod-build ]]; then
    cp /usr/bin/synapse-kmod-build "${MOUNT_POINT}/usr/bin/synapse-kmod-build"
    chmod 755 "${MOUNT_POINT}/usr/bin/synapse-kmod-build"
fi
# Copy synapse-kmod-build.service if not installed by package
if [[ ! -f "${MOUNT_POINT}/usr/lib/systemd/system/synapse-kmod-build.service" ]] && \
   [[ ! -f "${MOUNT_POINT}/etc/systemd/system/synapse-kmod-build.service" ]]; then
    if [[ -f /etc/systemd/system/synapse-kmod-build.service ]]; then
        mkdir -p "${MOUNT_POINT}/etc/systemd/system"
        cp /etc/systemd/system/synapse-kmod-build.service \
            "${MOUNT_POINT}/etc/systemd/system/"
    elif [[ -f /usr/lib/systemd/system/synapse-kmod-build.service ]]; then
        mkdir -p "${MOUNT_POINT}/usr/lib/systemd/system"
        cp /usr/lib/systemd/system/synapse-kmod-build.service \
            "${MOUNT_POINT}/usr/lib/systemd/system/"
    fi
fi

# ── Copy model ────────────────────────────────────────────
if echo "${AI_FEATURES}" | grep -q "model"; then
    MODEL_SRC="/var/lib/synapd/models/synapse-7b-q4_k_m.gguf"
    MODEL_DST="${MOUNT_POINT}/var/lib/synapd/models/"
    if [[ -f "${MODEL_SRC}" ]]; then
        log "Copying AI model (~4GB)..."
        mkdir -p "${MODEL_DST}"
        cp "${MODEL_SRC}" "${MODEL_DST}"
        ok "Model installed"
    else
        log "Model not found on live ISO — will download on first boot"
        mkdir -p "${MOUNT_POINT}/etc/synapseos"
        echo "download_model=true" >> "${MOUNT_POINT}/etc/synapseos/firstboot.conf"
    fi
fi

# ── fstab ─────────────────────────────────────────────────
log "Generating fstab..."
genfstab -U "${MOUNT_POINT}" > "${MOUNT_POINT}/etc/fstab"
ok "fstab written"

# ── Write password file outside heredoc to avoid double shell expansion ──
# NOTE: must NOT use /tmp — arch-chroot mounts tmpfs over it
printf '%s:%s\n' "${USERNAME}" "${USER_PASS}" > "${MOUNT_POINT}/root/.syninstall-cred"
chmod 600 "${MOUNT_POINT}/root/.syninstall-cred"

# ── chroot config ─────────────────────────────────────────
log "Configuring installed system..."
arch-chroot "${MOUNT_POINT}" /bin/bash -s << CHROOT
set -e

# Locale
echo "${LOCALE} UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=${LOCALE}" > /etc/locale.conf
echo "KEYMAP=${KEYMAP}" > /etc/vconsole.conf

# Timezone
ln -sf "/usr/share/zoneinfo/${TIMEZONE}" /etc/localtime
hwclock --systohc

# Hostname
echo "${HOSTNAME}" > /etc/hostname
cat > /etc/hosts << 'HOSTS'
127.0.0.1   localhost
::1         localhost
127.0.1.1   ${HOSTNAME}.localdomain ${HOSTNAME}
HOSTS

# Groups
groupadd -r synapse  2>/dev/null || true
groupadd -r synguard 2>/dev/null || true

# Register synsh in /etc/shells so PAM pam_shells accepts it
grep -qxF '/usr/bin/synsh' /etc/shells 2>/dev/null || echo '/usr/bin/synsh' >> /etc/shells

# User — add to seat group for seatd/DRM access
groupadd -r seat 2>/dev/null || true
# Login shell must pass pam_shells stat() check — use bash (always exists).
# synsh is available as a command; synui launches foot -e synsh for its terminal.
useradd -m -G wheel,audio,video,input,synapse,seat -s /bin/bash -c "${USER_FULL}" "${USERNAME}" 2>/dev/null || true
# Bypass PAM (-c) — PAM-based chpasswd can silently misfire inside arch-chroot
chpasswd -c YESCRYPT < /root/.syninstall-cred
rm -f /root/.syninstall-cred
echo "%wheel ALL=(ALL:ALL) ALL" > /etc/sudoers.d/wheel

# ── Desktop environment configuration ────────────────────
mkdir -p /etc/synapseos
echo "DE=${DESKTOP}" > /etc/synapseos/desktop.conf

USER_UID=\$(id -u "${USERNAME}")

case "${DESKTOP}" in
    synui)
        # Override synui.service to run as the created user
        mkdir -p /etc/systemd/system/synui.service.d
        cat > /etc/systemd/system/synui.service.d/user.conf << SYNUI_OVERRIDE
[Unit]
Conflicts=getty@tty1.service

[Service]
User=${USERNAME}
Environment=XDG_RUNTIME_DIR=/run/user/\${USER_UID}
ExecStartPre=
ExecStartPre=/bin/mkdir -p /run/user/\${USER_UID}
ExecStartPre=/bin/chown ${USERNAME}:${USERNAME} /run/user/\${USER_UID}
ExecStartPre=/bin/sh -c 'if [ -f /sys/class/dmi/id/sys_vendor ] && grep -qiE "VirtualBox|VMware|QEMU|KVM|Xen|innotek" /sys/class/dmi/id/sys_vendor; then mkdir -p /run/synui; printf "WLR_RENDERER=pixman\nWLR_BACKENDS=drm,libinput\nWLR_NO_HARDWARE_CURSORS=1\n" > /run/synui/env; else mkdir -p /run/synui; : > /run/synui/env; fi'
SYNUI_OVERRIDE

        # Override synui-foot.service to run as the user
        mkdir -p /etc/systemd/system/synui-foot.service.d
        cat > /etc/systemd/system/synui-foot.service.d/user.conf << FOOT_OVERRIDE
[Service]
User=${USERNAME}
Environment=XDG_RUNTIME_DIR=/run/user/\${USER_UID}
ExecStartPre=
ExecStartPre=/bin/sh -c 'n=0; while [ ! -S /run/user/\${USER_UID}/wayland-0 ] && [ ! -S /run/user/\${USER_UID}/wayland-1 ]; do sleep 0.5; n=\\$((n+1)); if [ \\$n -ge 30 ]; then echo "Timed out waiting for Wayland socket" >&2; exit 1; fi; done'
ExecStart=
ExecStart=/bin/sh -c 'WAYLAND_DISPLAY=\\$(cat /tmp/synui-display) exec foot -e synsh'
FOOT_OVERRIDE

        # User's .bash_profile — launch synui when logging in on tty1
        cat > /home/${USERNAME}/.bash_profile << 'BASH_PROFILE'
# SynapseOS — launch compositor on tty1
if [ "\$(tty)" = "/dev/tty1" ] && [ -z "\$WAYLAND_DISPLAY" ]; then
    export XDG_RUNTIME_DIR="/run/user/\$(id -u)"
    mkdir -p "\$XDG_RUNTIME_DIR"
    # VM detection — software renderer fallback
    if [ -f /sys/class/dmi/id/sys_vendor ] && \
       grep -qiE 'VirtualBox|VMware|QEMU|KVM|Xen|innotek' /sys/class/dmi/id/sys_vendor 2>/dev/null; then
        export WLR_RENDERER=pixman
        export WLR_BACKENDS=drm,libinput
        export WLR_NO_HARDWARE_CURSORS=1
    fi
    export XDG_SESSION_TYPE=wayland
    export LIBSEAT_BACKEND=seatd
    exec synui
fi
BASH_PROFILE
        chown ${USERNAME}:${USERNAME} /home/${USERNAME}/.bash_profile

        # synui config for the user
        mkdir -p /home/${USERNAME}/.config/synui
        cat > /home/${USERNAME}/.config/synui/synuirc << 'SYNUIRC'
# synui compositor configuration
terminal = foot
autostart = foot
border_width    = 2
gap             = 8
master_factor   = 0.60
ai_layout       = on
ai_ctx_decor    = on
start_overlay   = off
workspace_1_intent = main workspace
workspace_2_intent = web browsing and research
workspace_3_intent = writing code and running tests
workspace_4_intent = terminal and system administration
workspace_5_intent = media and entertainment
SYNUIRC
        chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}/.config

        # Enable synui services
        systemctl enable synui.service
        systemctl enable seatd.service
        ;;

    kde)
        # KDE Plasma — uses systemd-logind for seat management (not seatd)
        systemctl enable sddm.service
        ;;

    gnome)
        # GNOME — uses systemd-logind for seat management (not seatd)
        systemctl enable gdm.service
        ;;

    tty)
        # TTY only — no compositor, no display manager
        ;;
esac

# ── Core services (always enabled) ───────────────────────
systemctl enable synapd.service
systemctl enable synguard.service
systemctl enable NetworkManager.service
systemctl enable synapse-kmod-build.service 2>/dev/null || true

# Mark firstboot done — installer already configured everything
mkdir -p /var/lib/synapseos
echo "firstboot completed by installer: \$(date)" > /var/lib/synapseos/firstboot.done

# Kernel module — DKMS builds it for the installed kernel
dkms autoinstall 2>/dev/null || true

# Ensure module loads at boot even if DKMS built it outside modules-load.d
if [[ ! -f /usr/lib/modules-load.d/synapse.conf ]] && \
   [[ ! -f /etc/modules-load.d/synapse.conf ]]; then
    mkdir -p /etc/modules-load.d
    echo "synapse_kmod" > /etc/modules-load.d/synapse.conf
fi
if [[ ! -f /usr/lib/modprobe.d/synapse.conf ]] && \
   [[ ! -f /etc/modprobe.d/synapse.conf ]]; then
    mkdir -p /etc/modprobe.d
    echo "options synapse_kmod synapse_events=1 synapse_sched=1 synapse_daemon_timeout=30 synapse_ring_size=4096" \
        > /etc/modprobe.d/synapse.conf
fi

# GRUB
grub-install --target=x86_64-efi \
    --efi-directory=/boot/efi \
    --bootloader-id=SynapseOS \
    --recheck

# Customize GRUB
cat >> /etc/default/grub << 'GRUBCONF'
GRUB_DISTRIBUTOR="SynapseOS"
GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 nowatchdog"
GRUB_COLOR_NORMAL="cyan/black"
GRUB_COLOR_HIGHLIGHT="white/cyan"
GRUBCONF

grub-mkconfig -o /boot/grub/grub.cfg

# initramfs
mkinitcpio -P

CHROOT

ok "System configured"

# ── Unmount ───────────────────────────────────────────────
log "Unmounting..."
umount -R "${MOUNT_POINT}"
ok "Done"

} # end do_install

do_install 2>&1 | tee -a "$LOG"

# ── Done ──────────────────────────────────────────────────────
clear

case "${DESKTOP}" in
    synui) DE_LABEL="SynapseUI (AI compositor)" ;;
    kde)   DE_LABEL="KDE Plasma" ;;
    gnome) DE_LABEL="GNOME" ;;
    tty)   DE_LABEL="TTY only" ;;
esac

dialog --backtitle "SynapseOS Installer" \
       --title "✓ Installation Complete" \
       --msgbox "\n\
SynapseOS has been installed successfully!\n\
\n\
