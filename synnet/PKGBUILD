pkgname=synnet
pkgver=0.1.0
pkgrel=1
pkgdesc="SynapseOS AI Network Policy Daemon"
arch=('x86_64')
license=('GPL2')
depends=('nftables' 'synapd')
makedepends=('meson' 'ninja')
source=("synnet-0.1.0.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/synnet-0.1.0"
    meson setup build --prefix=/usr
    ninja -C build
}

package() {
    cd "$srcdir/synnet-0.1.0"
    DESTDIR="$pkgdir" ninja -C build install
    install -Dm644 synnet.service         "$pkgdir/usr/lib/systemd/system/synnet.service"
}
