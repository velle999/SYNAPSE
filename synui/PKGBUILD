pkgname=synui
pkgver=0.1.0
pkgrel=1
pkgdesc="SynapseOS Wayland Compositor"
arch=('x86_64')
license=('GPL2')
depends=('wlroots0.19' 'wayland' 'libxkbcommon' 'pixman' 'seatd')
makedepends=('meson' 'ninja' 'wayland-protocols' 'pkg-config')
source=("synui-0.1.0.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/synui-0.1.0"
    meson setup build --prefix=/usr --buildtype=release
    ninja -C build
}

package() {
    cd "$srcdir/synui-0.1.0"
    DESTDIR="$pkgdir" ninja -C build install

    install -Dm644 systemd/synui.service \
        "$pkgdir/usr/lib/systemd/system/synui.service"
    install -Dm644 systemd/synui-foot.service \
        "$pkgdir/usr/lib/systemd/system/synui-foot.service"
}
